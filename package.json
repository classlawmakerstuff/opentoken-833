{
	"name": "opentoken-monorepo",
	"version": "2.0.0",
	"private": true,
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/MrGray17/opentoken",
	"bugs": {
		"url": "https://github.com/MrGray17/opentoken/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/MrGray17/opentoken.git"
	},
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"checks:regex": "bun run scripts/check-regex-safety.ts",
		"lint": "biome check packages/",
		"lint:fix": "biome check --write packages/",
		"build": "bun run typecheck && bun run lint && bun run checks:regex && bun test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@mrgray17/opentoken": "workspace:*",
		"@mrgray17/opentoken-core": "workspace:*",
		"@types/bun": "^1.3.14",
		"typescript": "^5.9.3"
	}
}
